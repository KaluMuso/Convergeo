    "typecheck": "tsc --noEmit",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "1.56.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.2"
  }
}
