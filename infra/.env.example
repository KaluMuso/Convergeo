# Vergeo5 OCI runtime — names only. Copy to infra/.env and fill locally.
# Never commit infra/.env.

# --- API (FastAPI) ---
# Prebuilt image tag pulled from GHCR (built by api-image.yml). Defaults to :latest;
# set to a git SHA to pin a specific build for reproducible deploy / rollback.
API_IMAGE_TAG=latest
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# Direct Postgres connection string for server-side SQL (ledger, reconciliation).
SUPABASE_DB_URL=
ENV=
LOG_LEVEL=
CORS_ORIGINS=

# --- Payments: Lenco ---
# Secret API token (Bearer; issued/rotated via Lenco support — treat as a password).
# Rotating this also re-keys webhook verification (signing key = sha256(token)).
LENCO_API_TOKEN=
# sandbox | production. Defaults to production when unset.
LENCO_ENV=
# Optional: override only if Lenco's sandbox REST base differs from the built-in default.
LENCO_SANDBOX_BASE_URL=
# Merchant account id — used by payouts/reconciliation (resolved from /accounts if unset).
LENCO_ACCOUNT_ID=
# Optional: 1/true to enable Zamtel USSD collections (gated pending F9a).
LENCO_ENABLE_ZAMTEL_COLLECTIONS=

# --- Notifications: WhatsApp Cloud API (official only — WAHA forbidden) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Optional: Graph API version (has a built-in default).
WHATSAPP_API_VERSION=

# --- Notifications: SMS fallback (Africa's Talking) ---
# Use LIVE credentials — the adapter targets AT's production messaging endpoint.
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=

# --- Notifications: Email fallback (Resend) ---
RESEND_API_KEY=
# Optional: from-address (defaults to notifications@vergeo5.com).
RESEND_FROM_EMAIL=

# --- Internal cron tokens (shared secrets sent as X-Internal-Token) ---
# Generate each with `openssl rand -hex 32`. Never ship the insecure dev defaults.
INTERNAL_RECONCILIATION_TOKEN=
INTERNAL_PAYMENT_SWEEPER_TOKEN=
INTERNAL_N8N_TOKEN=
INTERNAL_DISPATCH_TOKEN=
INTERNAL_DIGEST_TOKEN=
INTERNAL_EMBEDDINGS_TOKEN=
INTERNAL_EVENT_RELEASE_TOKEN=
INTERNAL_FUNNEL_TOKEN=
INTERNAL_JOB_COMPLETION_TOKEN=
INTERNAL_ORDER_JOBS_TOKEN=
INTERNAL_PAYOUTS_TOKEN=
INTERNAL_RELEASE_JOB_TOKEN=
INTERNAL_REVIEW_AGGREGATE_TOKEN=
INTERNAL_STOCK_SWEEPER_TOKEN=
INTERNAL_TICKETS_ISSUE_TOKEN=

# --- Ops alerts ---
# E.164 WhatsApp number for founder alerts (payout failures, reconciliation).
FOUNDER_WHATSAPP_E164=

# --- Caddy / host routing ---
API_DOMAIN=api.vergeo5.com
VENDOR_DOMAIN=vendor.vergeo5.com
ADMIN_DOMAIN=admin.vergeo5.com
N8N_DOMAIN=n8n.vergeo5.com
VENDOR_UPSTREAM=host.docker.internal:3001
ADMIN_UPSTREAM=host.docker.internal:3002
# Space-separated CIDRs for Caddy remote_ip matcher (set at deploy)
ADMIN_ALLOWED_IPS=127.0.0.1/32 10.0.0.0/8

# --- n8n ---
N8N_HOST=
N8N_PROTOCOL=https
N8N_ENCRYPTION_KEY=
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=
WEBHOOK_URL=

# --- TLS / ACME (optional overrides) ---
ACME_EMAIL=
