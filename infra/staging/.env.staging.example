# Vergeo5 OCI *staging* runtime — names only. Copy to ~/vergeo5-api-staging.env
# (API standalone) and/or infra/staging/.env (compose). Never commit filled values.
# ENV must be staging. Production identifiers are forbidden (see
# infra/staging/forbidden-production-identifiers.env).

# --- Identity / isolation ---
ENV=staging
# Canonical staging API hostname (existing DNS convention: api.staging.vergeo5.com).
# Proposed alternate staging-api.vergeo5.com is NOT used — follow ENVIRONMENTS.md.
PUBLIC_API_HOST=api.staging.vergeo5.com
API_DOMAIN=api.staging.vergeo5.com
# Immutable image tag = git SHA (never "latest" on staging).
API_IMAGE_TAG=
GIT_SHA=
SENTRY_RELEASE=

# --- Supabase staging project (MUST ≠ dpadrlxukcjbewpqympu) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_DB_URL=

# --- API process ---
LOG_LEVEL=INFO
# Include staging/preview frontend origins only — never production-only CORS if avoidable.
CORS_ORIGINS=

# --- Payments: Lenco sandbox / mock only ---
LENCO_ENV=sandbox
LENCO_API_TOKEN=
LENCO_SANDBOX_BASE_URL=
LENCO_ACCOUNT_ID=
PAYMENTS_ENABLED=true
# Must remain unset/false on staging — live production ack is forbidden.
PAYMENTS_ALLOW_PRODUCTION=false

# --- Outbound / payouts (suppressed by default when ENV=staging) ---
# Leave unset so WhatsApp/SMS/email and payouts are noop/blocked.
# STAGING_ALLOW_OUTBOUND=false
# STAGING_ALLOW_PAYOUTS=false

# --- Notifications (staging-only credentials if outbound explicitly allowed) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Internal cron tokens (staging-only; distinct from production) ---
INTERNAL_RECONCILIATION_TOKEN=
INTERNAL_PAYMENT_SWEEPER_TOKEN=
INTERNAL_N8N_TOKEN=
INTERNAL_DISPATCH_TOKEN=
INTERNAL_DIGEST_TOKEN=
INTERNAL_EMBEDDINGS_TOKEN=
INTERNAL_EVENT_RELEASE_TOKEN=
INTERNAL_FUNNEL_TOKEN=
INTERNAL_JOB_COMPLETION_TOKEN=
INTERNAL_ORDER_JOBS_TOKEN=
INTERNAL_PAYOUTS_TOKEN=
INTERNAL_RELEASE_JOB_TOKEN=
INTERNAL_REVIEW_AGGREGATE_TOKEN=
INTERNAL_STOCK_SWEEPER_TOKEN=
INTERNAL_TICKETS_ISSUE_TOKEN=

FOUNDER_WHATSAPP_E164=

# --- Caddy / host routing (staging) ---
VENDOR_DOMAIN=vendor.staging.vergeo5.com
ADMIN_DOMAIN=admin.staging.vergeo5.com
N8N_DOMAIN=n8n.staging.vergeo5.com
VENDOR_UPSTREAM=host.docker.internal:3001
ADMIN_UPSTREAM=host.docker.internal:3002
ADMIN_ALLOWED_IPS="127.0.0.1/32 10.0.0.0/8"

# --- n8n staging ---
N8N_HOST=n8n.staging.vergeo5.com
N8N_PROTOCOL=https
N8N_ENCRYPTION_KEY=
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=
WEBHOOK_URL=https://n8n.staging.vergeo5.com/
# Workflows must call the staging API (never api.vergeo5.com).
API_URL=https://api.staging.vergeo5.com

ACME_EMAIL=
