# Vercel Preview environment variables for the dedicated `staging` git branch.
# Configure in each Vercel project → Settings → Environment Variables →
# Environment: Preview → Git Branch: staging.
#
# Applies to: convergeo-customer, convergeo-vendor, convergeo-admin
# (branch-scoped Preview — no separate staging Vercel projects required).
#
# NEVER place service-role keys, Lenco tokens, or other secrets in NEXT_PUBLIC_*.
# NEVER use localhost fallbacks for staging Preview values.
# Staging API/DB identifiers MUST differ from production
# (see infra/staging/forbidden-production-identifiers.env).

# --- Shared (all three apps) ---
# Public Supabase staging URL (project ref ≠ dpadrlxukcjbewpqympu)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Staging API — canonical hostname api.staging.vergeo5.com
NEXT_PUBLIC_API_BASE_URL=https://api.staging.vergeo5.com

# Non-secret build fingerprint (also available as VERCEL_GIT_COMMIT_SHA at runtime)
NEXT_PUBLIC_VERGEO_BUILD_ID=
NEXT_PUBLIC_VERGEO_ENV=staging

# --- Customer (convergeo-customer) Preview / staging branch ---
# Cross-link to vendor Preview/staging URL (not vendor.vergeo5.com, not localhost)
NEXT_PUBLIC_VENDOR_APP_URL=
NEXT_PUBLIC_SITE_URL=

# --- Vendor (convergeo-vendor) Preview / staging branch ---
# Admin uses NEXT_PUBLIC_VERGEO_API_URL (different name — set explicitly)
# NEXT_PUBLIC_API_BASE_URL=https://api.staging.vergeo5.com

# --- Admin (convergeo-admin) Preview / staging branch ---
NEXT_PUBLIC_VERGEO_API_URL=https://api.staging.vergeo5.com

# Forbidden on Vercel (any environment):
# SUPABASE_SERVICE_ROLE_KEY
# LENCO_API_TOKEN
# INTERNAL_* tokens
