{
  "name": "Uptime Downtime Founder Alert",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "uptime-alert",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "uptimerobot-webhook",
      "name": "UptimeRobot Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 320],
      "webhookId": "uptime-alert"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const crypto = require('crypto');\nconst item = items[0].json;\nconst headers = item.headers || {};\nconst providedRaw = headers['x-uptime-secret'] ?? headers['X-Uptime-Secret'] ?? '';\nconst provided = String(providedRaw);\nconst expected = String($env.UPTIME_WEBHOOK_SECRET || '');\nlet authOk = false;\nif (expected.length > 0 && provided.length === expected.length) {\n  authOk = crypto.timingSafeEqual(Buffer.from(provided, 'utf8'), Buffer.from(expected, 'utf8'));\n} else if (expected.length > 0) {\n  // Length mismatch: still exercise timingSafeEqual on equal-length buffers\n  // so the failure path does not short-circuit purely on length.\n  crypto.timingSafeEqual(Buffer.from(expected, 'utf8'), Buffer.from(expected, 'utf8'));\n  authOk = false;\n}\nreturn [{ json: { ...item, authOk } }];"
      },
      "id": "verify-uptime-secret",
      "name": "Verify Uptime Secret",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 320]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.authOk}}",
              "value2": true
            }
          ]
        }
      },
      "id": "auth-ok",
      "name": "Auth OK",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [680, 320]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"ok\": false, \"error\": \"unauthorized\" } }}",
        "options": {
          "responseCode": 401
        }
      },
      "id": "respond-unauthorized",
      "name": "Respond 401 Unauthorized",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [920, 480]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.body.alertType}}",
              "operation": "equal",
              "value2": "1"
            }
          ]
        }
      },
      "id": "is-down",
      "name": "Only When Down",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [920, 220]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v21.0/{{$env.WHATSAPP_PHONE_NUMBER_ID}}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.WHATSAPP_CLOUD_API_TOKEN}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{$env.FOUNDER_WHATSAPP_TO}}\",\n  \"type\": \"template\",\n  \"template\": {\n    \"name\": \"ops_uptime_alert\",\n    \"language\": { \"code\": \"en\" },\n    \"components\": [\n      {\n        \"type\": \"body\",\n        \"parameters\": [\n          { \"type\": \"text\", \"text\": \"{{$json.body.monitorFriendlyName}}\" },\n          { \"type\": \"text\", \"text\": \"{{$json.body.alertDetails}}\" },\n          { \"type\": \"text\", \"text\": \"{{$json.body.alertDateTime}}\" }\n        ]\n      }\n    ]\n  }\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "page-founder-whatsapp",
