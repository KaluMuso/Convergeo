{
  "name": "Reconciliation Poller & Daily Report",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 30
            }
          ]
        }
      },
      "id": "schedule-poll",
      "name": "Every Thirty Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [260, 280]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.API_URL}}/internal/reconciliation/poll-tick",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Internal-Token",
              "value": "={{$env.INTERNAL_RECONCILIATION_TOKEN}}"
            }
          ]
        },
        "options": {
          "timeout": 60000
        }
      },
      "id": "reconciliation-poll-tick",
      "name": "Poll Non-Terminal Payments",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 280],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "Vergeo5 Internal Reconciliation"
        }
      }
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 5 * * *"
            }
          ]
        }
      },
      "id": "schedule-daily",
      "name": "Daily At 05:00 UTC",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [260, 520]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.API_URL}}/internal/reconciliation/daily-report",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Internal-Token",
              "value": "={{$env.INTERNAL_RECONCILIATION_TOKEN}}"
            }
          ]
        },
        "options": {
          "timeout": 120000
        }
      },
      "id": "reconciliation-daily-report",
      "name": "Run Daily Reconciliation",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 520],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "Vergeo5 Internal Reconciliation"
        }
      }
    }
  ],
  "connections": {
    "Every Thirty Minutes": {
      "main": [
        [
          {
            "node": "Poll Non-Terminal Payments",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Daily At 05:00 UTC": {
      "main": [
        [
          {
            "node": "Run Daily Reconciliation",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
