{
  "name": "Payment Sweeper Tick",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 5
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Every Five Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [260, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.API_URL}}/internal/payment-sweeper/tick",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Internal-Token",
              "value": "={{$env.INTERNAL_PAYMENT_SWEEPER_TOKEN}}"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      },
      "id": "payment-sweeper-tick",
      "name": "Sweep Stale Payments",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "Vergeo5 Internal Payment Sweeper"
        }
      }
    },
    {
      "parameters": {},
      "id": "error-trigger",
      "name": "On Workflow Error",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [260, 560]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const src = items[0].json || {};\nconst exec = src.execution || {};\nconst message = [\n  'Vergeo5 money workflow failure',\n  'workflow: Payment Sweeper Tick',\n  `status: ${String(exec.status || 'error').slice(0, 40)}`,\n  `lastNode: ${String(exec.lastNodeExecuted || 'n/a').slice(0, 60)}`,\n  `at: ${new Date().toISOString()}`,\n].join('\\n');\nreturn [{ json: { message } }];"
      },
      "id": "sanitize-error",
      "name": "Sanitize Error Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [520, 560]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v21.0/{{$env.WHATSAPP_PHONE_NUMBER_ID}}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.WHATSAPP_CLOUD_API_TOKEN}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{$env.FOUNDER_WHATSAPP_TO}}\",\n  \"type\": \"text\",\n  \"text\": { \"body\": {{ JSON.stringify($json.message) }} }\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "page-founder-on-error",
      "name": "Page Founder On Error",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [780, 560]
    }
  ],
  "connections": {
    "Every Five Minutes": {
      "main": [
        [
          {
            "node": "Sweep Stale Payments",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "On Workflow Error": {
      "main": [
        [
          {
            "node": "Sanitize Error Payload",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Sanitize Error Payload": {
      "main": [
        [
          {
            "node": "Page Founder On Error",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "versionId": "vd-p06-payment-sweeper",
  "meta": {
    "templateCredsSetupCompleted": false
  },
