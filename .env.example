SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ADMIN_BYPASS=
# Client API + media base. NEXT_PUBLIC_* are inlined at BUILD time, so set these
# before building apps/customer and REBUILD after changing them. If API base is
# blank in prod, browser cart/wishlist calls fail closed to same-origin (404);
# if the Cloudinary cloud name is blank, product/category/hero images render blank.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# Google OAuth (Supabase Auth external provider — see docs/ops/auth-providers.md)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
LENCO_API_TOKEN=
LENCO_BASE_URL=
OPENROUTER_API_KEY=
WHATSAPP_TOKEN=
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=
SEND_SMS_HOOK_SECRET=
RESEND_API_KEY=
CLOUDINARY_URL=
