{
  "name": "vergeo5",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --config packages/config/prettier.config.mjs --write .",
    "format:check": "prettier --config packages/config/prettier.config.mjs --check .",
    "verify-scaffold": "node scripts/verify-scaffold.mjs",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.39.5",
    "@lhci/cli": "^0.15.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "lefthook": "^1.11.3",
    "lint-staged": "^15.5.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.64.0"
  },
  "lint-staged": {
    "*": "prettier --config packages/config/prettier.config.mjs --write --ignore-unknown"
  }
}
