{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "url": [
        "http://localhost:3000/en",
        "http://localhost:3000/en/c/electronics",
        "http://localhost:3000/en/p/smartphone-x1",
        "http://localhost:3000/en/search",
        "http://localhost:3000/en/checkout"
      ],
      "settings": {
        "formFactor": "mobile",
        "screenEmulation": {
          "mobile": true,
          "width": 360,
          "height": 740,
          "deviceScaleFactor": 2,
          "disabled": false
        },
        "throttling": {
          "rttMs": 150,
          "throughputKbps": 1600,
          "requestLatencyMs": 150,
          "downloadThroughputKbps": 1600,
          "uploadThroughputKbps": 750,
          "cpuSlowdownMultiplier": 4
        },
        "onlyCategories": ["performance", "accessibility", "seo", "best-practices"]
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": "http://localhost:3000/en/checkout/?$",
          "assertions": {
            "categories:accessibility": ["error", { "minScore": 0.9 }],
            "categories:best-practices": ["error", { "minScore": 0.85 }],
            "categories:seo": ["warn", { "minScore": 0.4 }],
            "categories:performance": ["error", { "minScore": 0.5 }],
            "largest-contentful-paint": ["error", { "maxNumericValue": 6500 }]
          }
        },
        {
          "matchingUrlPattern": "http://localhost:3000/en/search/?$",
          "assertions": {
            "categories:accessibility": ["error", { "minScore": 0.9 }],
            "categories:best-practices": ["error", { "minScore": 0.85 }],
            "categories:seo": ["error", { "minScore": 0.4 }],
            "categories:performance": ["error", { "minScore": 0.5 }],
            "largest-contentful-paint": ["error", { "maxNumericValue": 6500 }]
          }
        },
        {
          "matchingUrlPattern": "http://localhost:3000/en/?$",
          "assertions": {
            "categories:accessibility": ["error", { "minScore": 0.9 }],
            "categories:best-practices": ["error", { "minScore": 0.85 }],
            "categories:seo": ["error", { "minScore": 0.75 }],
            "categories:performance": ["error", { "minScore": 0.5 }],
            "largest-contentful-paint": ["error", { "maxNumericValue": 6500 }]
          }
        },
        {
          "matchingUrlPattern": "http://localhost:3000/en/c/.+",
          "assertions": {
            "categories:accessibility": ["error", { "minScore": 0.9 }],
            "categories:best-practices": ["error", { "minScore": 0.85 }],
            "categories:seo": ["error", { "minScore": 0.75 }],
            "categories:performance": ["error", { "minScore": 0.5 }],
            "largest-contentful-paint": ["error", { "maxNumericValue": 6500 }]
          }
        },
        {
          "matchingUrlPattern": "http://localhost:3000/en/p/.+",
          "assertions": {
            "categories:accessibility": ["error", { "minScore": 0.9 }],
            "categories:best-practices": ["error", { "minScore": 0.85 }],
            "categories:seo": ["error", { "minScore": 0.75 }],
            "categories:performance": ["error", { "minScore": 0.5 }],
            "largest-contentful-paint": ["error", { "maxNumericValue": 6500 }]
          }
        }
      ]
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  },
  "vergeo": {
    "bundle": {
      "defaultMaxKbGz": 150,
      "defaultJustification": "CLAUDE.md convention #7 — customer routes ≤150 KB gz first-load JS on Fast-3G/360px devices.",
      "reductionNote": "2026-07: code-split @vergeo/auth (the Supabase browser client) off first-load via a lazy getBrowserClient accessor — useSession and every direct consumer now import it dynamically. Dropped ~60 KB gz from each customer route (PDP 195→131, auth/checkout/account routes 184–192→120–128), bringing ALL 47 routes under the 150 KB target, so the per-route overrides (previously up to 197 KB) are gone and the default 150 now genuinely gates every route.",
      "routes": {},
      "auditRoutes": [
        "/[locale]/(shop)/page",
        "/[locale]/(shop)/c/[...slug]/page",
        "/[locale]/(shop)/p/[slug]/page",
        "/[locale]/(shop)/search/page",
        "/[locale]/(shop)/checkout/page"
      ]
    },
    "lighthouse": {
      "profile": "Fast-3G / 360×740 mobile",
      "justification": "Zambia 3G guardrail from docs/plan/00-discovery.md — RTT 150ms, 1.6 Mbps downlink, 4× CPU slowdown.",
      "productionTargets": {
        "performance": 0.9,
        "seo": 0.95,
        "accessibility": 0.95,
        "bestPractices": 0.9,
        "lcpMs": 2500
      },
      "ciEnforced": {
        "performance": 0.5,
        "seoCatalog": 0.75,
        "seoSearch": 0.4,
        "accessibility": 0.9,
        "bestPractices": 0.85,
        "lcpMs": 6500,
        "baselineRun": "2026-07-20 CI cold next start (commit 9d5d694): home Perf 0.60 / SEO 0.82; search A11y 0.94 / BP 0.89 / SEO 0.45; checkout Perf 0.69 / A11y 0.94 / LCP ~5200ms. Floors sit ~0.05–0.10 below those scores to catch severe regressions without flake. Bundle-guard remains the hard ≤150 KB gz JS budget.",
        "waiver": "Cold local `next start` under 4× CPU throttle with Cloudinary=demo under-scores vs a warm Vercel preview/CDN. Production G19 (Perf≥90 / SEO≥95 / A11y≥95 / LCP≤2.5s) remains the launch target once LHCI runs against a real preview URL."
      },
      "waivers": [
        {
          "url": "/en/checkout",
          "seo": "warn only — route is noindex by design (M05-P09); a11y/perf/best-practices still error."
        },
        {
          "url": "/en/search",
          "seo": "CI floor 0.40 — search SERP often lacks full SEO surface in local fixture; production target remains 0.95."
        }
      ]
    }
  }
}
